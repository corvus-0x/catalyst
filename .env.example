# .env.example — copy this to .env and fill in your values
# NEVER commit .env to git. It is in .gitignore already.
#
# ─── QUICK START (Docker — recommended) ────────────────────────────────────
#   1. cp .env.example .env
#   2. Fill in DJANGO_SECRET_KEY and ANTHROPIC_API_KEY below
#   3. docker compose up -d
#   4. docker compose exec backend python manage.py seed_demo
#   5. open http://localhost:5173
#
# ─── NATIVE DEV (without Docker) ──────────────────────────────────────────
#   Set DB_HOST=127.0.0.1  DB_PORT=5433  (native PostgreSQL 18)
#   Then: cd backend && python manage.py runserver
#         cd frontend && npm run dev
# ──────────────────────────────────────────────────────────────────────────

# Django — SECRET_KEY is REQUIRED (server won't start without it)
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace_with_a_long_random_string

# Set to True for local development. Defaults to False if omitted.
DJANGO_DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# Database — local dev uses a plain postgres container on port 5434
# The postgres:16-alpine image creates a "postgres" superuser by default.
# DB_PASSWORD here is the password for that user.
DB_PASSWORD=changeme_local_only
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=catalyst_db
POSTGRES_USER=postgres

# AI features (optional — leave blank to disable)
# ANTHROPIC_API_KEY=

# API Token Authentication (optional — leave blank for local dev)
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# CATALYST_API_TOKEN=
